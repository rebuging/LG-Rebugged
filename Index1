<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>LG-Rebugged Console</title>
<style>
body{font-family:sans-serif;background:#141414;color:#eee;padding:20px;max-width:520px;margin:auto;}
h1{color:#5bc0de;font-size:22px;margin:0 0 16px;}
h3{font-size:14px;color:#aaa;margin:22px 0 8px;text-transform:uppercase;letter-spacing:1px;}
button{background:#2c2c2c;color:#eee;border:1px solid #555;padding:12px 16px;margin:4px 4px 4px 0;
  border-radius:6px;font-size:15px;cursor:pointer;width:100%;box-sizing:border-box;}
button:active{background:#444;}
button.primary{background:#1a3a4a;border-color:#5bc0de;color:#5bc0de;}
button:disabled{opacity:0.35;}
input{padding:10px;border-radius:6px;border:1px solid #555;background:#2a2a2a;color:#eee;
  font-size:14px;width:100%;box-sizing:border-box;margin-bottom:8px;}
#status{margin:10px 0;padding:10px;border-radius:6px;background:#1e1e1e;font-size:13px;border-left:3px solid #555;}
#status.ok{border-color:#5bc0de;}
#status.err{border-color:#c0392b;}
#log{background:#0c0c0c;padding:10px;margin-top:16px;border-radius:6px;height:160px;
  overflow-y:auto;font-family:monospace;font-size:11px;white-space:pre-wrap;color:#7fbf7f;}
.row{display:flex;gap:8px;}
.row input{flex:1;margin:0;}
.row button{width:auto;white-space:nowrap;}
iframe{display:none;}
</style>
</head>
<body>
<h1>LG-Rebugged Console</h1>

<div class="row">
  <input id="tvIp" placeholder="TV IP" value="10.0.0.129"/>
  <button class="primary" onclick="connect()">Connect</button>
</div>
<div id="status">Not connected</div>

<h3>Install IPK</h3>
<input id="ipkUrl" placeholder="Paste direct .ipk URL here (GitHub release link)" />
<button class="needsConn" disabled onclick="installIpk()">⬇ Install via Homebrew Channel</button>

<h3>Toast Message</h3>
<div class="row">
  <input id="msg" placeholder="Message to show on TV"/>
  <button class="needsConn" disabled onclick="sendToast()">Send</button>
</div>

<h3>Controls</h3>
<button class="needsConn" disabled onclick="send('ssap://audio/volumeUp')">Vol +</button>
<button class="needsConn" disabled onclick="send('ssap://audio/volumeDown')">Vol -</button>
<button class="needsConn" disabled onclick="send('ssap://audio/setMute',{mute:true})">Mute</button>
<button class="needsConn" disabled onclick="send('ssap://system/turnOff')">Power Off</button>

<div id="log"></div>
<iframe id="proxy"></iframe>

<script>
// --- Proxy code runs inside data: iframe (null origin = TV allows it) ---
var proxyCode = '<scr'+'ipt>var ws=null;window.addEventListener("message",function(e){var m=e.data;if(m.cmd==="open"){try{ws=new WebSocket(m.url);ws.onopen=function(){parent.postMessage({ev:"open"},"*")};ws.onclose=function(){parent.postMessage({ev:"close"},"*")};ws.onerror=function(){parent.postMessage({ev:"error"},"*")};ws.onmessage=function(e){parent.postMessage({ev:"message",data:e.data},"*")}}catch(ex){parent.postMessage({ev:"error",detail:String(ex)},"*")}}else if(m.cmd==="send"&&ws&&ws.readyState===1){ws.send(m.data)}});parent.postMessage({ev:"ready"},"*");<\/scr'+'ipt>';

var proxy = document.getElementById('proxy');
proxy.src = 'data:text/html;charset=utf-8,' + encodeURIComponent(proxyCode);

var proxyReady = false, paired = false, msgId = 0;

var manifest = {
  manifestVersion:1, appVersion:"1.1",
  permissions:["LAUNCH","LAUNCH_WEBAPP","APP_TO_APP","CLOSE",
    "CONTROL_AUDIO","CONTROL_DISPLAY","CONTROL_POWER",
    "READ_INSTALLED_APPS","READ_RUNNING_APPS",
    "WRITE_NOTIFICATION_TOAST","WRITE_NOTIFICATION_ALERT"]
};

function log(m){var el=document.getElementById('log');el.innerHTML+=m+"\n";el.scrollTop=el.scrollHeight;}
function setStatus(m,cls){var el=document.getElementById('status');el.textContent=m;el.className=cls||'';}
function enable(on){document.querySelectorAll('.needsConn').forEach(function(b){b.disabled=!on;});}
function wsSend(obj){proxy.contentWindow.postMessage({cmd:'send',data:JSON.stringify(obj)},'*');}

window.addEventListener('load',function(){
  var host=location.hostname;
  if(host&&host!=='localhost'&&host!==''){document.getElementById('tvIp').value=host;}
});

window.addEventListener('message',function(e){
  var m=e.data;
  if(m.ev==='ready'){proxyReady=true;}
  else if(m.ev==='open'){
    log('Connected — registering...');
    var ip=document.getElementById('tvIp').value.trim();
    var key=localStorage.getItem('tvkey_'+ip);
    var payload={forcePairing:false,pairingType:'PROMPT',manifest:manifest};
    if(key)payload['client-key']=key;
    wsSend({type:'register',id:'register_0',payload:payload});
    setStatus('👋 Accept the prompt on your TV screen...');
  }
  else if(m.ev==='message'){
    var d;try{d=JSON.parse(m.data);}catch(_){return;}
    log('<- '+JSON.stringify(d));
    if(d.type==='registered'){
      var ip=document.getElementById('tvIp').value.trim();
      if(d.payload&&d.payload['client-key'])localStorage.setItem('tvkey_'+ip,d.payload['client-key']);
      paired=true;
      setStatus('✅ Connected & paired!','ok');
      enable(true);
    } else if(d.type==='error'){
      setStatus('TV error: '+(d.error||''),'err');
    }
  }
  else if(m.ev==='error'){setStatus('❌ Connection failed — see log','err');log('Error: '+(m.detail||''));}
  else if(m.ev==='close'){setStatus('Disconnected','err');paired=false;enable(false);}
});

function connect(){
  var ip=document.getElementById('tvIp').value.trim();
  if(!ip){alert('Enter TV IP');return;}
  if(!proxyReady){setTimeout(connect,500);return;}
  paired=false;enable(false);
  setStatus('Connecting to '+ip+'...');
  log('Opening ws://'+ip+':3000');
  proxy.contentWindow.postMessage({cmd:'open',url:'ws://'+ip+':3000'},'*');
}

function send(uri,payload){
  if(!paired){alert('Not paired yet');return;}
  payload=payload||{};
  var msg={type:'request',id:'req_'+(msgId++),uri:uri,payload:payload};
  log('-> '+JSON.stringify(msg));
  wsSend(msg);
}

function sendToast(){
  var message=document.getElementById('msg').value||'Hello TV!';
  send('ssap://system.notifications/createToast',{message:message});
}

function installIpk(){
  var url=document.getElementById('ipkUrl').value.trim();
  if(!url){alert('Paste the .ipk URL first');return;}
  if(!url.endsWith('.ipk')){alert('URL must end in .ipk — use the direct asset link from GitHub Releases');return;}
  log('Installing: '+url);
  // Try Homebrew Channel install service
  send('ssap://org.webosbrew.hbchannel.service/install',{ipkUrl:url});
  setStatus('📦 Install sent — watch your TV screen...','ok');
}
</script>
</body>
</html>
